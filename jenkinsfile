// https://github.com/Santosh-Pathak/E-Commerce-App
/*@Library('Shared') _ -> This is the Shaed Library which is used to call the common functions 
which are defined in the Shared Library. This is used to avoid code duplication and to keep the
 Jenkinsfile clean and maintainable. The functions defined in the Shared Library can be used a
 cross multiple Jenkinsfiles by simply calling them with the appropriate parameters.
 https://github.com/Santosh-Pathak/jenkins-shared-libraries
 Register in Jenkins as: easyshop-shared-lib (see JENKINS.md)
*/
@Library('easyshop-shared-lib') _

pipeline {
    agent any

    environment {
        // Update the main app image name to match the deployment file
        DOCKER_IMAGE_NAME = 'Santosh-Pathak/E-Commerce-App'
        DOCKER_MIGRATION_IMAGE_NAME = 'Santosh-Pathak/E-Commerce-App-migration'
        DOCKER_IMAGE_TAG = "${BUILD_NUMBER}"
        GIT_BRANCH = 'main'
        GIT_REPO = 'https://github.com/Santosh-Pathak/E-Commerce-App.git'
    }

    stages {
        stage('Cleanup Workspace') {
            steps {
                script {
                    clean_ws()
                }
            }
        }

        stage('Clone Repository') {
            steps {
                script {
                    // checkout() replaces clone() — shared library clone() only accepts (url, branch)
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${GIT_BRANCH}"]],
                        userRemoteConfigs: [[
                            url: "${GIT_REPO}",
                            credentialsId: 'github-credentials'
                        ]]
                    ])
                }
            }
        }

        stage('Build Docker Images') {
            parallel {
                stage('Build Main App Image') {
                    steps {
                        script {
                            docker_build(
                                imageName: env.DOCKER_IMAGE_NAME,
                                imageTag: env.DOCKER_IMAGE_TAG,
                                dockerfile: 'Dockerfile',
                                context: '.'
                            )
                        }
                    }
                }

                stage('Build Migration Image') {
                    steps {
                        script {
                            docker_build(
                                imageName: env.DOCKER_MIGRATION_IMAGE_NAME,
                                imageTag: env.DOCKER_IMAGE_TAG,
                                dockerfile: 'scripts/Dockerfile.migration',
                                context: '.'
                            )
                        }
                    }
                }
            }
        }

        stage('Run Unit Tests') {
            steps {
                script {
                    // run_tests() is a no-op in the shared library; lint is the available quality gate
                    sh 'docker run --rm -v "$PWD":/app -w /app node:20-alpine sh -c "npm ci && npm run lint"'
                }
            }
        }

        stage('Security Scan with Trivy') {
            steps {
                script {
                    // Create directory for results

                    trivy_scan()
                }
            }
        }

        stage('Push Docker Images') {
            parallel {
                stage('Push Main App Image') {
                    steps {
                        script {
                            docker_push(
                                imageName: env.DOCKER_IMAGE_NAME,
                                imageTag: env.DOCKER_IMAGE_TAG,
                                credentials: 'docker-hub-credentials'
                            )
                        }
                    }
                }

                stage('Push Migration Image') {
                    steps {
                        script {
                            docker_push(
                                imageName: env.DOCKER_MIGRATION_IMAGE_NAME,
                                imageTag: env.DOCKER_IMAGE_TAG,
                                credentials: 'docker-hub-credentials'
                            )
                        }
                    }
                }
            }
        }

        // Add this new stage
        // it basically updates the kubernetes manifests with the new image tag
        // it uses the update_k8s_manifests function from the shared library
        // the function is defined in the shared library and is used to update the kubernetes manifests
        // the function takes the following parameters:
        // - imageTag: the new image tag
        // - manifestsPath: the path to the kubernetes manifests
        // - gitCredentials: the git credentials
        // - gitUserName: the git user name
        // - gitUserEmail: the git user email
        // it is used to update the kubernetes manifests with the new image tag i.e 1 , 2, 3 etc etc
        // NOTE: implemented inline below (sed + git push) so image names match 08 & 12 manifests

        stage('Update Kubernetes Manifests') {
            steps {
                script {
                    sh """
                        sed -i 's|image: ${DOCKER_IMAGE_NAME}:.*|image: ${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG}|' kubernetes/08-easyshop-deployment.yml
                        sed -i 's|image: ${DOCKER_MIGRATION_IMAGE_NAME}:.*|image: ${DOCKER_MIGRATION_IMAGE_NAME}:${DOCKER_IMAGE_TAG}|' kubernetes/12-migration-job.yml
                    """
                    withCredentials([usernamePassword(
                        credentialsId: 'github-credentials',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh """
                            git config user.name "Jenkins CI"
                            git config user.email "pathaksantosh987@gmail.com"
                            git add kubernetes/08-easyshop-deployment.yml kubernetes/12-migration-job.yml
                            if git diff --staged --quiet; then
                              echo "Manifest image tags already up to date."
                            else
                              git commit -m "ci: update image tags to ${DOCKER_IMAGE_TAG}"
                              git push https://\${GIT_USER}:\${GIT_TOKEN}@github.com/Santosh-Pathak/E-Commerce-App.git HEAD:${GIT_BRANCH}
                            fi
                        """
                    }
                }
            }
        }
    }
}
